# ===========================================
# Warband Nexus — WoW addon repository policy
# ===========================================
# Tracked content is allowlisted at the end: only the addon tree that ships
# under Interface/AddOns/WarbandNexus. Everything else is ignored and must
# not be committed.

# Cursor / IDE / AI tooling
.cursor/
.claude/
.vscode/
.idea/

# Debug / logs
*.log
debug.log
*.debug

# WoW SavedVariables (never commit user data)
SavedVariables/

# Backups
*.bak
*.backup
*~
*.orig

# OS junk
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Temp / editor swap
*.tmp
.tmp/
Locales/.tmp/
*.temp
*.swp
*.swo

# Archives / packager output
*.zip
*.rar
*.7z
.release/
build/
WarbandNexus/

# Dev / docs / tooling (not part of the in-game addon)
*.md
/CHANGES.txt
tests/
/test_*.lua
/test2.lua
build_addon.*
update_locales.lua
docs/
_enc_w.html
.pkgmeta
.gitattributes

# Screenshots (listing assets, not addon runtime)
Screenshots/*.png
Screenshots/*.jpg
Screenshots/*.jpeg

# ---------------------------------------------------------------------------
# Allowlist: only these paths are tracked (WoW addon payload).
# Later rules win; keep this block last except for fine-grained re-ignores.
# ---------------------------------------------------------------------------
/*
!.gitignore

!WarbandNexus.toc
!Core.lua
!Config.lua
!embeds.xml
!Bindings.xml
!LICENSE

!/Modules/
!/Modules/**

!/Locales/
!/Locales/**

!/libs/
!/libs/**

!/Fonts/
!/Fonts/**

!/Media/
!/Media/**

# Vendor / lib docs are non-runtime but kept with embedded libs
libs/**/*.md
